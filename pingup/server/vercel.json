{
  "version": 2,
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "functions": {
    "server.js": {
      "includeFiles": "{config/**,models/**,routes/**,controllers/**,middleware/**,inngest/**,node_modules/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}